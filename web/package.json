{
  "name": "datapilot-web",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @datapilot/chat-ui dev",
    "build": "pnpm --filter @datapilot/chat-ui build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,css}\"",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  }
}
