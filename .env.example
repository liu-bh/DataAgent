# ============================================
# Agent Service
# ============================================
AGENT_PORT=8000
AGENT_HOST=0.0.0.0
AGENT_DATABASE_URL=postgresql+asyncpg://datapilot:datapilot@localhost:5432/datapilot
AGENT_REDIS_URL=redis://localhost:6379/0
AGENT_LOG_LEVEL=INFO
AGENT_DEBUG=false
AGENT_TENANT_ID=default

# ============================================
# Semantic Service
# ============================================
SEMANTIC_PORT=8001
SEMANTIC_DATABASE_URL=postgresql+asyncpg://datapilot:datapilot@localhost:5432/datapilot
SEMANTIC_REDIS_URL=redis://localhost:6379/1

# ============================================
# SQL Generator Service
# ============================================
SQLGEN_PORT=8002
SQLGEN_DATABASE_URL=postgresql+asyncpg://datapilot:datapilot@localhost:5432/datapilot
SQLGEN_REDIS_URL=redis://localhost:6379/2
SQLGEN_DEFAULT_DIALECT=mysql
SQLGEN_MAX_CORRECTION_ROUNDS=3
SQLGEN_DRYRUN_ENABLED=true
SQLGEN_SCAN_ROW_LIMIT=1000000

# ============================================
# Query Executor Service
# ============================================
QUERYEXEC_PORT=8003
QUERYEXEC_REDIS_URL=redis://localhost:6379/3
QUERYEXEC_MINIO_ENDPOINT=localhost:9000
QUERYEXEC_MINIO_BUCKET=query-results
QUERYEXEC_DEFAULT_LIMIT=1000
QUERYEXEC_MAX_EXPORT_ROWS=100000

# ============================================
# Auth Service
# ============================================
AUTH_PORT=8004
AUTH_DATABASE_URL=postgresql+asyncpg://datapilot:datapilot@localhost:5432/datapilot
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars-long
JWT_ACCESS_TOKEN_EXPIRE=900
JWT_REFRESH_TOKEN_EXPIRE=604800

# ============================================
# Guardrail Service
# ============================================
GUARDRAIL_PORT=8005
GUARDRAIL_DATABASE_URL=postgresql+asyncpg://datapilot:datapilot@localhost:5432/datapilot
SQL_RISK_THRESHOLD=medium
USER_DAILY_QUERY_LIMIT=100
USER_HOURLY_SCAN_LIMIT=500000

# ============================================
# Session Service
# ============================================
SESSION_PORT=8006
SESSION_DATABASE_URL=postgresql+asyncpg://datapilot:datapilot@localhost:5432/datapilot
SESSION_REDIS_URL=redis://localhost:6379/4
SESSION_TIMEOUT_SECONDS=1800
SESSION_MAX_MESSAGES=50
SESSION_RETENTION_DAYS=90

# ============================================
# LLM 配置
# ============================================
LLM_DEFAULT_PROVIDER=deepseek
LLM_DEFAULT_MODEL=deepseek-v3
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1536

# ============================================
# 产品授权
# ============================================
LICENSE_FILE_PATH=./license.json
LICENSE_SIGNING_KEY=

# ============================================
# 前端
# ============================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_SENTRY_DSN=
VITE_APP_TITLE=DataPilot
